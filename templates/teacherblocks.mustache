{{!
    @template report_lmsace_reports/teacherblocks.

    Template for the teacher reports.

    Example context (json):
    {
    }
}}

{{#enableteacherblock}}

    <div class="teacher-report-block position-relative">

        {{^reportbase}}
            <div class="teacher-filters-panel block-report mb-4">
                <div class="main-panel">
                    <div class="header-panel">
                        <div class="heading-block">
                            <h5><i class="fa fa-filter mr-2"></i>{{#str}} filterbymonth, report_lmsace_reports {{/str}}</h5>
                        </div>
                    </div>
                    <div class="body-panel p-3">
                        <div class="row">
                            <div class="col-md-4 mb-2">
                                {{{teacherform}}}
                            </div>
                            {{#hasteacherselected}}
                            <div class="col-md-3 mb-2">
                                <label for="teacher-month-select" class="small font-weight-bold text-muted mb-1 d-block">
                                    <i class="fa fa-calendar mr-1"></i>{{#str}} filterbymonth, report_lmsace_reports {{/str}}
                                </label>
                                <select id="teacher-month-select" class="form-control form-control-sm">
                                    {{#teachermonthfilter}}
                                    <option value="{{value}}" {{selected}}>{{label}}</option>
                                    {{/teachermonthfilter}}
                                </select>
                            </div>
                            <div class="col-md-3 mb-2">
                                <label class="small font-weight-bold text-muted mb-1 d-block">
                                    <i class="fa fa-sitemap mr-1"></i>{{#str}} filterbycategory, report_lmsace_reports {{/str}}
                                </label>
                                {{#teachercategoryfilter}}
                                <div class="border rounded p-2" style="max-height:200px; overflow-y:auto; background:#f8f9fa;">
                                    {{> report_lmsace_reports/widgets/teachercategorytree }}
                                </div>
                                {{/teachercategoryfilter}}
                                {{^teachercategoryfilter}}
                                <div class="text-muted small p-2">{{#str}} nocategories, report_lmsace_reports {{/str}}</div>
                                {{/teachercategoryfilter}}
                            </div>
                            <div class="col-md-2 mb-2 d-flex align-items-end">
                                <div class="w-100">
                                    <button type="button" id="teacher-apply-filters" class="btn btn-primary btn-sm btn-block mb-1">
                                        <i class="fa fa-check mr-1"></i>{{#str}} applyfilter, report_lmsace_reports {{/str}}
                                    </button>
                                    <button type="button" id="teacher-clear-filters" class="btn btn-outline-secondary btn-sm btn-block">
                                        <i class="fa fa-times mr-1"></i>{{#str}} clearfilter, report_lmsace_reports {{/str}}
                                    </button>
                                </div>
                            </div>
                            {{/hasteacherselected}}
                        </div>
                    </div>
                </div>
            </div>

            {{^hasteacherselected}}
            <div class="alert alert-info">
                <i class="fa fa-info-circle mr-2"></i>{{#str}} selectteacher, report_lmsace_reports {{/str}}
            </div>
            {{/hasteacherselected}}
        {{/reportbase}}

        {{#noteacherreports}}
            <p class="no-teacher-reports alert alert-info"> {{#str}} noteacherreports, report_lmsace_reports {{/str}} </p>
        {{/noteacherreports}}

        {{#reportbase}}
        <div class="nav-item refresh-button position-absolute">
            <a href="{{{purgeurl}}}" data-toggle="tooltip" title="{{#str}} reload, report_lmsace_reports {{/str}}"
                class="btn btn-primary"> <i class="fa fa-refresh"> </i>
                {{#str}} reload, report_lmsace_reports {{/str}}
            </a>
        </div>
        {{/reportbase}}

        {{#stackteacherreports}}
        <div class="lmsace-reports count-block">
            <ul>
                <li><a href="#"><i class="fa fa-users"></i> <span><b>{{totalstudents}}</b> {{#str}} totalstudents, report_lmsace_reports {{/str}}</span></a></li>
                <li><a href="#"><i class="fa fa-book"></i> <span><b>{{totalcourses}}</b> {{#str}} courses {{/str}}</span></a></li>
                <li><a href="#"><i class="fa fa-check-circle-o"></i> <span><b>{{avgcompletionrate}}%</b> {{#str}} avgcompletionrate, report_lmsace_reports {{/str}}</span></a></li>
                <li><a href="#"><i class="fa fa-cubes"></i> <span><b>{{totalactivities}}</b> {{#str}} totalactivities, report_lmsace_reports {{/str}}</span></a></li>
            </ul>
        </div>
        {{/stackteacherreports}}

        <div class="row">

            {{#teachercoursessummary}}
            <div class="col-md-12">
                <div class="teacher-courses-summary-block block-report">
                    <div class="main-panel">
                        <div class="header-panel">
                            <div class="heading-block">
                                <h5> {{#str}} teachercoursessummarywidget, report_lmsace_reports {{/str}}</h5>
                            </div>
                        </div>
                        <div class="body-panel">
                            <div id="teacher-courses-summary-reports">
                                {{{teachercoursessummary}}}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {{/teachercoursessummary}}

            {{#teacherstudentperformance}}
            <div class="col-md-6">
                <div class="teacher-studentperformance-block block-report">
                    <div class="main-panel">
                        <div class="header-panel">
                            <div class="heading-block">
                                <h5> {{#str}} teacherstudentperformancewidget, report_lmsace_reports {{/str}}</h5>
                            </div>
                        </div>
                        <div class="body-panel">
                            <canvas id="teacher-studentperformance-chart" width="100" height="100"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            {{/teacherstudentperformance}}

            {{#teachergradingoverview}}
            <div class="col-md-6">
                <div class="teacher-gradingoverview-block block-report">
                    <div class="main-panel">
                        <div class="header-panel">
                            <div class="heading-block">
                                <h5> {{#str}} teachergradingoverviewwidget, report_lmsace_reports {{/str}}</h5>
                            </div>
                        </div>
                        <div class="body-panel">
                            <canvas id="teacher-gradingoverview-chart" width="100" height="100"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            {{/teachergradingoverview}}

            {{#teacheractivitycompletion}}
            <div class="col-md-12">
                <div class="teacher-activitycompletion-block block-report">
                    <div class="main-panel">
                        <div class="header-panel">
                            <div class="heading-block">
                                <h5> {{#str}} teacheractivitycompletionwidget, report_lmsace_reports {{/str}}</h5>
                            </div>
                            <div class="filter-block">
                                <div class="dropdown show">
                                    <a class="btn btn-outline-secondary dropdown-toggle lmsace-filter-btn" href="#" role="button" id="filter-teacheractivitycompletion" {{datatoggle}} aria-haspopup="true" aria-expanded="false"><i class="fa fa-filter"></i> {{#str}} lastyear, report_lmsace_reports {{/str}}
                                    </a>
                                    <div class="dropdown-menu dropdown-menu-right" aria-labelledby="filter-teacheractivitycompletion">
                                        <a class="dropdown-item" href="#" data-value="week">{{#str}} lastweek, report_lmsace_reports {{/str}}</a>
                                        <a class="dropdown-item" href="#" data-value="month">{{#str}} lastmonth, report_lmsace_reports {{/str}}</a>
                                        <a class="dropdown-item active" href="#" data-value="year">{{#str}} lastyear, report_lmsace_reports {{/str}}</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="loadiconElement"></div>
                        <div class="body-panel">
                            <canvas id="teacher-activitycompletion-chart" width="100" height="400"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            {{/teacheractivitycompletion}}

        </div>
    </div>
{{/enableteacherblock}}

{{^enableteacherblock}}
    <div class="no-teachers-block">
        <div class="alert alert-info"> {{#str}} noteachers, report_lmsace_reports {{/str}}</div>
    </div>
{{/enableteacherblock}}
