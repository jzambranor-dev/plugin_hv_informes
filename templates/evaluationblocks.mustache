{{!
    @template report_lmsace_reports/evaluationblocks

    Template for the evaluation reports tab.

    Example context (json):
    {
    }
}}

{{#enableevaluationblock}}

    <div class="evaluation-report-block position-relative">

        {{^reportbase}}
            <div class="evaluation-block report-lmsace-selector">{{{evalform}}}</div>
        {{/reportbase}}

        {{#noevaluationreports}}
            <p class="no-evaluation-reports alert alert-info">{{#str}} noevaluationreports, report_lmsace_reports {{/str}}</p>
        {{/noevaluationreports}}

        {{#reportbase}}
        <div class="nav-item refresh-button position-absolute">
            <a href="{{{purgeurl}}}" data-toggle="tooltip" title="{{#str}} reload, report_lmsace_reports {{/str}}"
                class="btn btn-primary"> <i class="fa fa-refresh"> </i>
                {{#str}} reload, report_lmsace_reports {{/str}}
            </a>
        </div>
        {{/reportbase}}

        {{! Breadcrumb navigation }}
        {{#hasevalbreadcrumb}}
        <nav aria-label="breadcrumb" class="mt-3 mb-3">
            <ol class="breadcrumb">
                {{#evalbreadcrumb}}
                <li class="breadcrumb-item {{#active}}active{{/active}}">
                    {{#active}}{{label}}{{/active}}
                    {{^active}}<a href="{{{url}}}">{{label}}</a>{{/active}}
                </li>
                {{/evalbreadcrumb}}
            </ol>
        </nav>
        {{/hasevalbreadcrumb}}

        {{! Step 1: Stack stats (shown when teacher is selected) }}
        {{#stackevaluationreports}}
        <div class="lmsace-reports count-block">
            <ul>
                <li><a href="#"><i class="fa fa-users"></i> <span><b>{{totalstudents}}</b> {{#str}} totalstudents, report_lmsace_reports {{/str}}</span></a></li>
                <li><a href="#"><i class="fa fa-book"></i> <span><b>{{totalcourses}}</b> {{#str}} courses {{/str}}</span></a></li>
                <li><a href="#"><i class="fa fa-check-circle-o"></i> <span><b>{{avgcompletionrate}}%</b> {{#str}} avgcompletionrate, report_lmsace_reports {{/str}}</span></a></li>
                <li><a href="#"><i class="fa fa-cubes"></i> <span><b>{{totalactivities}}</b> {{#str}} totalactivities, report_lmsace_reports {{/str}}</span></a></li>
            </ul>
        </div>
        {{/stackevaluationreports}}

        {{! Step 0: Consolidated view (no teacher selected) }}
        {{#showconsolidated}}
        <div class="row mb-3">
            <div class="col-md-12">
                <div class="evaluation-consolidated-block block-report">
                    <div class="main-panel">
                        <div class="header-panel">
                            <div class="heading-block">
                                <h5>{{#str}} consolidatedreport, report_lmsace_reports {{/str}}</h5>
                            </div>
                        </div>
                        <div id="eval-month-filter-form" class="mb-3 p-3 border rounded bg-light">
                            <div class="d-flex flex-wrap align-items-end gap-2 mb-2">
                                <div>
                                    <label for="eval-month-filter" class="form-label mb-0 small">
                                        {{#str}} filterbymonth, report_lmsace_reports {{/str}}
                                    </label>
                                    <select id="eval-month-filter" class="form-select form-select-sm custom-select">
                                        {{#evalmonthfilter}}
                                        <option value="{{value}}" {{selected}}>{{label}}</option>
                                        {{/evalmonthfilter}}
                                    </select>
                                </div>
                                <div>
                                    <label for="eval-conmodtype-filter" class="form-label mb-0 small">
                                        {{#str}} filterbyactivitytype, report_lmsace_reports {{/str}}
                                    </label>
                                    <select id="eval-conmodtype-filter" class="form-select form-select-sm custom-select">
                                        {{#evalconmodtypefilter}}
                                        <option value="{{value}}" {{selected}}>{{label}}</option>
                                        {{/evalconmodtypefilter}}
                                    </select>
                                </div>
                                <div>
                                    <button type="button" id="eval-month-apply" class="btn btn-primary btn-sm">
                                        {{#str}} applyfilter, report_lmsace_reports {{/str}}
                                    </button>
                                    <button type="button" id="eval-month-clear" class="btn btn-secondary btn-sm">
                                        {{#str}} clearfilter, report_lmsace_reports {{/str}}
                                    </button>
                                </div>
                            </div>
                            {{#hascategoryaccordion}}
                            <div class="mt-2">
                                <label class="form-label mb-1 small fw-bold">
                                    <i class="fa fa-folder-open"></i> {{#str}} filterbycategory, report_lmsace_reports {{/str}}
                                </label>
                                <div class="accordion eval-cat-accordion" id="evalCategoryAccordion">
                                    {{#evalcategoryaccordion}}
                                    <div class="accordion-item border-0 mb-1">
                                        <div class="d-flex align-items-center bg-white rounded px-2 py-1" style="border:1px solid #e0e5ec;">
                                            <input type="checkbox" class="eval-cat-checkbox eval-cat-parent form-check-input mt-0 me-2"
                                                value="{{parentid}}" id="eval-cat-{{parentid}}" data-parent="1" {{parentchecked}}>
                                            {{#haschildren}}
                                            <a class="flex-grow-1 text-decoration-none text-dark small fw-semibold py-1 {{collapsedclass}}"
                                                data-toggle="collapse" data-bs-toggle="collapse"
                                                href="#evalCatCollapse{{idx}}" role="button"
                                                aria-expanded="{{expanded}}" aria-controls="evalCatCollapse{{idx}}">
                                                <i class="fa fa-chevron-right eval-cat-arrow me-1" style="font-size:10px;transition:transform .2s;"></i>
                                                {{parentname}}
                                            </a>
                                            {{/haschildren}}
                                            {{^haschildren}}
                                            <label for="eval-cat-{{parentid}}" class="flex-grow-1 mb-0 small fw-semibold py-1 cursor-pointer">
                                                {{parentname}}
                                            </label>
                                            {{/haschildren}}
                                        </div>
                                        {{#haschildren}}
                                        <div id="evalCatCollapse{{idx}}" class="collapse {{showclass}}" data-parent="#evalCategoryAccordion" data-bs-parent="">
                                            <div class="py-1 ps-4">
                                                {{#children}}
                                                <div class="form-check py-0" style="padding-left:{{indent}}px;">
                                                    <input type="checkbox" class="eval-cat-checkbox eval-cat-child form-check-input"
                                                        value="{{id}}" id="eval-cat-{{id}}" data-parentid="{{../parentid}}" {{checked}}>
                                                    <label class="form-check-label small" for="eval-cat-{{id}}">{{name}}</label>
                                                </div>
                                                {{/children}}
                                            </div>
                                        </div>
                                        {{/haschildren}}
                                    </div>
                                    {{/evalcategoryaccordion}}
                                </div>
                            </div>
                            {{/hascategoryaccordion}}
                        </div>
                        <div class="body-panel">
                            {{{consolidatedtablehtml}}}
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{/showconsolidated}}

        <div class="row">

            {{! Step 2: Courses list (when teacher selected, no course selected) }}
            {{#evaluationcourses}}
            <div class="col-md-12">
                <div class="evaluation-courses-block block-report">
                    <div class="main-panel">
                        <div class="header-panel">
                            <div class="heading-block">
                                <h5>{{#str}} evaluationcourses, report_lmsace_reports {{/str}}</h5>
                            </div>
                        </div>
                        <div class="body-panel">
                            {{{evaluationcourses}}}
                        </div>
                    </div>
                </div>
            </div>
            {{/evaluationcourses}}

            {{! Step 3: Activities list (when course selected, no activity selected) }}
            {{#evaluationactivities}}
            <div class="col-md-12">
                <div class="evaluation-activities-block block-report">
                    <div class="main-panel">
                        <div class="header-panel">
                            <div class="heading-block">
                                <h5>{{#str}} activities, report_lmsace_reports {{/str}}</h5>
                            </div>
                        </div>

                        {{! Course summary bar }}
                        {{#coursesummarydata}}
                        <div class="alert alert-info d-flex flex-wrap gap-3 mb-3">
                            <span><strong>{{#str}} totalenrolled, report_lmsace_reports {{/str}}:</strong> {{totalenrolled}}</span>
                            <span><strong>{{#str}} totalcompleted, report_lmsace_reports {{/str}}:</strong> {{totalcompleted}}</span>
                        </div>
                        {{/coursesummarydata}}

                        {{! Filters bar }}
                        <form id="eval-filter-form" class="d-flex flex-wrap align-items-end gap-2 mb-3 p-2 border rounded bg-light" onsubmit="return false;">
                            <div>
                                <label for="eval-modtype-filter" class="form-label mb-0 small">{{#str}} filterbyactivitytype, report_lmsace_reports {{/str}}</label>
                                <select id="eval-modtype-filter" class="form-select form-select-sm custom-select">
                                    {{#modtypes}}
                                    <option value="{{value}}" {{selected}}>{{label}}</option>
                                    {{/modtypes}}
                                </select>
                            </div>
                            <div>
                                <label for="eval-datefrom" class="form-label mb-0 small">{{#str}} datefrom, report_lmsace_reports {{/str}}</label>
                                <input type="date" id="eval-datefrom" class="form-control form-control-sm"
                                    {{#evalfrom}}value="{{evalfromdate}}"{{/evalfrom}}>
                            </div>
                            <div>
                                <label for="eval-dateto" class="form-label mb-0 small">{{#str}} dateto, report_lmsace_reports {{/str}}</label>
                                <input type="date" id="eval-dateto" class="form-control form-control-sm"
                                    {{#evalto}}value="{{evaltodate}}"{{/evalto}}>
                            </div>
                            <div>
                                <button type="button" id="eval-apply-filter" class="btn btn-primary btn-sm">{{#str}} applyfilter, report_lmsace_reports {{/str}}</button>
                                <button type="button" id="eval-clear-filter" class="btn btn-secondary btn-sm">{{#str}} clearfilter, report_lmsace_reports {{/str}}</button>
                            </div>
                        </form>

                        <div class="body-panel">
                            {{{evaluationactivities}}}
                        </div>
                    </div>
                </div>
            </div>
            {{/evaluationactivities}}

            {{! Step 4: Activity detail (when activity selected) }}
            {{#evaluationactivitydetail}}
            <div class="col-md-12">
                <div class="evaluation-activitydetail-block block-report">
                    <div class="main-panel">
                        <div class="header-panel">
                            <div class="heading-block">
                                <h5>{{activityname}} <span class="badge bg-secondary badge-secondary">{{activitytype}}</span></h5>
                            </div>
                        </div>
                        <div class="body-panel">

                            {{! Summary stat cards row }}
                            <div class="row mb-4 justify-content-center">
                                <div class="col-6 col-sm-4 col-lg-2 mb-3">
                                    <div class="stat-card text-center p-3">
                                        <div class="stat-icon bg-primary-light"><i class="fa fa-users"></i></div>
                                        <div class="stat-value">{{enrolled}}</div>
                                        <div class="stat-label">{{#str}} enrolled, report_lmsace_reports {{/str}}</div>
                                    </div>
                                </div>
                                <div class="col-6 col-sm-4 col-lg-2 mb-3">
                                    <div class="stat-card text-center p-3">
                                        <div class="stat-icon bg-success-light"><i class="fa fa-check-circle"></i></div>
                                        <div class="stat-value">{{completed}}</div>
                                        <div class="stat-label">{{#str}} completedcount, report_lmsace_reports {{/str}}</div>
                                    </div>
                                </div>
                                <div class="col-6 col-sm-4 col-lg-2 mb-3">
                                    <div class="stat-card text-center p-3">
                                        <div class="stat-icon bg-warning-light"><i class="fa fa-clock-o"></i></div>
                                        <div class="stat-value">{{notcompleted}}</div>
                                        <div class="stat-label">{{#str}} notcompletedcount, report_lmsace_reports {{/str}}</div>
                                    </div>
                                </div>
                                <div class="col-6 col-sm-4 col-lg-2 mb-3">
                                    <div class="stat-card text-center p-3">
                                        <div class="stat-icon bg-green-light"><i class="fa fa-trophy"></i></div>
                                        <div class="stat-value">{{passed}}</div>
                                        <div class="stat-label">{{#str}} passedcount, report_lmsace_reports {{/str}}</div>
                                    </div>
                                </div>
                                <div class="col-6 col-sm-4 col-lg-2 mb-3">
                                    <div class="stat-card text-center p-3">
                                        <div class="stat-icon bg-danger-light"><i class="fa fa-times-circle"></i></div>
                                        <div class="stat-value">{{failed}}</div>
                                        <div class="stat-label">{{#str}} failedcount, report_lmsace_reports {{/str}}</div>
                                    </div>
                                </div>
                                <div class="col-6 col-sm-4 col-lg-2 mb-3">
                                    <div class="stat-card text-center p-3">
                                        <div class="stat-icon bg-info-light"><i class="fa fa-bar-chart"></i></div>
                                        <div class="stat-value">{{avggrade}}/10</div>
                                        <div class="stat-label">{{#str}} averagegrade, report_lmsace_reports {{/str}}</div>
                                    </div>
                                </div>
                            </div>

                            {{! Activity info + chart row }}
                            <div class="row mb-4 justify-content-center">
                                <div class="col-md-5 mb-3 mb-md-0">
                                    <div class="card">
                                        <div class="card-body">
                                            <h6 class="card-title">{{#str}} activitydetail, report_lmsace_reports {{/str}}</h6>
                                            <table class="table table-sm table-borderless mb-0">
                                                <tr>
                                                    <td style="width:40%"><strong>{{#str}} startdate, report_lmsace_reports {{/str}}</strong></td>
                                                    <td>{{#startdate}}{{startdate}}{{/startdate}}{{^startdate}}<span class="text-muted">{{#str}} notavailable, report_lmsace_reports {{/str}}</span>{{/startdate}}</td>
                                                </tr>
                                                <tr>
                                                    <td><strong>{{#str}} enddate, report_lmsace_reports {{/str}}</strong></td>
                                                    <td>{{#enddate}}{{enddate}}{{/enddate}}{{^enddate}}<span class="text-muted">{{#str}} notavailable, report_lmsace_reports {{/str}}</span>{{/enddate}}</td>
                                                </tr>
                                                <tr>
                                                    <td><strong>{{#str}} averagetime, report_lmsace_reports {{/str}}</strong></td>
                                                    <td>{{avgtime}}</td>
                                                </tr>
                                                <tr>
                                                    <td><strong>{{#str}} averagegrade, report_lmsace_reports {{/str}}</strong></td>
                                                    <td><strong style="color: #0c6;">{{avggrade}}/10</strong></td>
                                                </tr>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-7">
                                    <div class="card">
                                        <div class="card-body text-center">
                                            <h6 class="card-title">{{#str}} passfailchart, report_lmsace_reports {{/str}}</h6>
                                            <canvas id="evaluation-passfail-chart" width="280" height="280"
                                                data-passed="{{passed}}" data-failed="{{failed}}" data-notcompleted="{{notcompleted}}"></canvas>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            {{! Students who have not attempted }}
                            {{#hasnotattempted}}
                            <div class="card">
                                <div class="card-body">
                                    <h6 class="card-title">{{#str}} studentsnotattempted, report_lmsace_reports {{/str}} <span class="badge bg-secondary badge-secondary" style="font-size:0.8rem;">{{notattemptedcount}}</span></h6>
                                    <div class="table-responsive">
                                        <table class="table table-striped table-hover table-sm mb-0">
                                            <thead>
                                                <tr>
                                                    <th style="width:50px">#</th>
                                                    <th>{{#str}} name {{/str}}</th>
                                                    <th>{{#str}} email {{/str}}</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                {{#notattempted}}
                                                <tr>
                                                    <td>{{rownum}}</td>
                                                    <td>{{fullname}}</td>
                                                    <td>{{email}}</td>
                                                </tr>
                                                {{/notattempted}}
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                            {{/hasnotattempted}}

                            {{! Quiz average score per question chart }}
                            {{#hasquizattempts}}
                            <div class="card mt-4">
                                <div class="card-body text-center">
                                    <h6 class="card-title">{{#str}} avgscoreperquestion, report_lmsace_reports {{/str}}</h6>
                                    <div style="position:relative;">
                                        <canvas id="evaluation-question-avg-chart"
                                            data-labels="{{quizquestionlabelsjson}}"
                                            data-values="{{quizquestionavgsjson}}"
                                            data-maxmarks="{{quizquestionmaxjson}}"></canvas>
                                    </div>
                                </div>
                            </div>
                            {{/hasquizattempts}}

                            {{! Quiz attempts detail with per-question grades }}
                            {{#hasquizattempts}}
                            <div class="card mt-4">
                                <div class="card-body">
                                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center mb-3 text-center text-sm-left">
                                        <h6 class="card-title mb-2 mb-sm-0">
                                            {{#str}} quizattemptsdetail, report_lmsace_reports {{/str}}
                                            <span class="badge bg-secondary badge-secondary" style="font-size:0.8rem;">{{quizattemptscount}}</span>
                                        </h6>
                                        <a href="{{quizdetaildownloadurl}}" class="btn btn-sm btn-outline-success">
                                            <i class="fa fa-download"></i> {{#str}} downloadexcel, report_lmsace_reports {{/str}}
                                        </a>
                                    </div>
                                    <div class="table-responsive quiz-detail-table-wrap">
                                        <table class="table table-striped table-hover table-sm mb-0">
                                            <thead>
                                                <tr>
                                                    <th style="width:50px">#</th>
                                                    <th>{{#str}} name {{/str}}</th>
                                                    <th>{{#str}} email {{/str}}</th>
                                                    <th>{{#str}} idnumber {{/str}}</th>
                                                    {{#quizquestions}}
                                                    <th class="text-center" style="min-width:100px;">
                                                        {{questionname}}<br><small class="text-muted">({{maxmark}})</small>
                                                    </th>
                                                    {{/quizquestions}}
                                                    <th class="text-center">{{#str}} grade, report_lmsace_reports {{/str}}</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                {{#quizattempts}}
                                                <tr>
                                                    <td>{{rownum}}</td>
                                                    <td>{{fullname}}</td>
                                                    <td>{{email}}</td>
                                                    <td>{{idnumber}}</td>
                                                    {{#questionmarks}}
                                                    <td class="text-center">{{mark}}</td>
                                                    {{/questionmarks}}
                                                    <td class="text-center"><strong>{{grade}}</strong></td>
                                                </tr>
                                                {{/quizattempts}}
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                            {{/hasquizattempts}}
                        </div>
                    </div>
                </div>
            </div>
            {{/evaluationactivitydetail}}

        </div>
    </div>

{{/enableevaluationblock}}

{{^enableevaluationblock}}
    <div class="no-evaluation-block">
        <div class="alert alert-info">{{#str}} noevaluationteachers, report_lmsace_reports {{/str}}</div>
    </div>
{{/enableevaluationblock}}
